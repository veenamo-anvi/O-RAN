# ── O-RAN Orchestrator — LLM backend credentials ───────────────────────────
# Copy to `.env` and fill ONE backend, then:  docker compose up -d orchestrator
# Backend priority: Claude CLI → Anthropic API → Gemini → Mock.
# Leave everything unset to use the offline Mock backend (no LLM).

# ── Gemini (priority 3) ──
# GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic API (priority 2) ──
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL_NAME=sonnet

# ── Claude CLI (priority 1) ──
# Also mount the binary into the orchestrator container (volume in docker-compose.yml).
# CLAUDE_CLI_PATH=/usr/bin/claude
